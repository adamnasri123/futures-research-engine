# Copy this file to .env and fill in your own keys. NEVER commit .env.

# --- TopstepX / ProjectX API (live account access) ---
# Get these from your TopstepX dashboard -> Settings -> API Access.
# The API subscription must be active for loginKey auth to work.
TOPSTEP_USERNAME=your_topstepx_username
TOPSTEP_API_KEY=your_projectx_api_key

# --- Massive.com (historical futures bars for backtesting only) ---
# Free tier: 5 calls/min, ~2 years of history. Only needed to (re)build the
# backtest data caches — the live bot does not use it.
MASSIVE_API_KEY=your_massive_api_key
